{% assign section = include.section %}
{% assign title = include.title | default: section.title %}
{% assign items = include.items | default: section.items %}
{% assign carousel_id = include.id | default: section.id | default: title | default: 'project-carousel-bootstrap' | slugify %}
{% assign swipe_threshold = include.swipe_threshold | default: section.swipe_threshold | default: 44 %}
{% assign swipe_vertical_ratio = include.swipe_vertical_ratio | default: section.swipe_vertical_ratio | default: 1.0 %}
{% assign show_thumbnails = section.show_thumbnails %}
{% if include.show_thumbnails != null %}
  {% assign show_thumbnails = include.show_thumbnails %}
{% endif %}
{% if show_thumbnails == null %}
  {% assign show_thumbnails = true %}
{% endif %}

{% if items and items.size > 0 %}
  <section class="nerfies-section nerfies-bcarousel-section">
    {% if title %}
      <h2>{{ title }}</h2>
    {% endif %}

    <div class="nerfies-bcarousel">
      <div
        id="{{ carousel_id }}"
        class="carousel slide"
        data-ride="false"
        data-interval="false"
        data-pause="hover"
        data-wrap="true"
        data-bs-ride="false"
        data-bs-interval="false"
        data-swipe-threshold="{{ swipe_threshold }}"
        data-swipe-vertical-ratio="{{ swipe_vertical_ratio }}"
      >
        <div class="carousel-inner">
          {% for item in items %}
            <div class="carousel-item{% if forloop.first %} active{% endif %}" data-slide-index="{{ forloop.index0 }}">
              {% include project_media_item.liquid item=item default_loading='lazy' %}
            </div>
          {% endfor %}
        </div>

        {% if items.size > 1 %}
          <a
            class="carousel-control-prev nerfies-bcarousel__control"
            href="#{{ carousel_id }}"
            role="button"
            data-target="#{{ carousel_id }}"
            data-bs-target="#{{ carousel_id }}"
            data-slide="prev"
            data-bs-slide="prev"
            aria-label="Previous slide"
          >
            <span class="nerfies-bcarousel__control-icon" aria-hidden="true">&#10094;</span>
          </a>
          <a
            class="carousel-control-next nerfies-bcarousel__control"
            href="#{{ carousel_id }}"
            role="button"
            data-target="#{{ carousel_id }}"
            data-bs-target="#{{ carousel_id }}"
            data-slide="next"
            data-bs-slide="next"
            aria-label="Next slide"
          >
            <span class="nerfies-bcarousel__control-icon" aria-hidden="true">&#10095;</span>
          </a>
        {% endif %}
      </div>

      {% if items.size > 1 %}
        <div class="nerfies-bcarousel__meta">
          <p class="nerfies-bcarousel__count" aria-live="polite">
            <span data-bcarousel-current>1</span>
            <span class="nerfies-bcarousel__count-sep">/</span>
            <span data-bcarousel-total>{{ items.size }}</span>
          </p>
        </div>

        {% if show_thumbnails %}
          <div class="nerfies-bcarousel__thumbs" role="list" aria-label="{{ title | default: 'Carousel items' }}">
            {% for item in items %}
              {% assign thumb_path = item.thumb | default: item.thumbnail | default: item.poster | default: item.image | default: item.path %}
              {% assign thumb_alt = item.thumb_alt | default: item.alt | default: item.title | default: 'Carousel thumbnail' %}
              {% assign thumb_label = item.title | default: item.caption | default: 'Slide ' | append: forloop.index %}
              {% if thumb_path %}
                {% unless thumb_path contains '://' %}
                  {% assign thumb_path = thumb_path | relative_url %}
                {% endunless %}
              {% endif %}

              <button
                type="button"
                class="nerfies-bcarousel__thumb{% if forloop.first %} is-active{% endif %}"
                data-bcarousel-thumb
                data-slide-index="{{ forloop.index0 }}"
                aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
                aria-label="{{ thumb_label }}"
                title="{{ thumb_label }}"
              >
                {% if thumb_path %}
                  <img src="{{ thumb_path }}" alt="{{ thumb_alt }}" loading="lazy">
                {% else %}
                  <span class="nerfies-bcarousel__thumb-fallback">{{ forloop.index }}</span>
                {% endif %}
              </button>
            {% endfor %}
          </div>
        {% endif %}
      {% endif %}
    </div>
  </section>
{% endif %}
