{% if site.bib_search %}
  <script src="{{ '/assets/js/bibsearch.js' | relative_url | bust_file_cache }}" type="module"></script>
  <div class="bibsearch-container">
    <input type="text" id="bibsearch" spellcheck="false" autocomplete="off" class="search bibsearch-form-input" placeholder="Search papers">
    <button type="button" id="bibsearch-clear" class="bibsearch-clear" aria-label="Clear search" hidden>&times;</button>
  </div>
{% endif %}
