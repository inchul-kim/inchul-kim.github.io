---
layout: default
---
<article class="nerfies-project-page">
  <link rel="stylesheet" href="{{ '/assets/css/nerfies-project.css' | relative_url | bust_file_cache }}">
  {% assign use_affiliation_superscripts = false %}
  {% if page.authors %}
    {% for author in page.authors %}
      {% assign author_affiliation_ids = author.affiliation_ids | default: author.affiliations %}
      {% if author_affiliation_ids %}
        {% assign use_affiliation_superscripts = true %}
        {% break %}
      {% endif %}
    {% endfor %}
  {% endif %}
  {% if page.affiliations %}
    {% assign first_affiliation = page.affiliations | first %}
    {% if first_affiliation.id or first_affiliation.name %}
      {% assign use_affiliation_superscripts = true %}
    {% endif %}
  {% endif %}

  <header class="nerfies-hero">
    {% if page.project_kicker %}
      <p class="nerfies-kicker">{{ page.project_kicker }}</p>
    {% endif %}
    <h1 class="nerfies-title">{{ page.title }}</h1>
    {% if page.project_subtitle %}
      <p class="nerfies-subtitle">{{ page.project_subtitle }}</p>
    {% endif %}

    {% if page.authors %}
      <p class="nerfies-authors">
        {% assign first_author = true %}
        {% for author in page.authors %}
          {% unless first_author %}
            <span class="nerfies-separator">|</span>
          {% endunless %}
          {% include project_author_link.liquid author=author %}
          {% if use_affiliation_superscripts %}
            {% assign author_affiliation_ids = author.affiliation_ids | default: author.affiliations %}
            {% if author_affiliation_ids %}
              {% assign author_affiliation_text = author_affiliation_ids | join: ',' %}
              {% if author_affiliation_text == blank %}
                {% assign author_affiliation_text = author_affiliation_ids %}
              {% endif %}
              <sup class="nerfies-author-sup">{{ author_affiliation_text }}</sup>
            {% endif %}
          {% endif %}
          {% assign first_author = false %}
        {% endfor %}
      </p>
    {% endif %}

    {% if page.affiliations %}
      <p class="nerfies-affiliations">
        {% for affiliation in page.affiliations %}
          {% assign affiliation_name = affiliation.name | default: affiliation %}
          {% assign affiliation_id = affiliation.id | default: forloop.index %}
          <span>
            {% if use_affiliation_superscripts %}
              <sup class="nerfies-affiliation-sup">{{ affiliation_id }}</sup>
            {% endif %}
            {{ affiliation_name }}
          </span>
          {% unless forloop.last %}
            <span class="nerfies-dot">
              {%- if use_affiliation_superscripts %};{% else %}-{% endif -%}
            </span>
          {% endunless %}
        {% endfor %}
      </p>
    {% endif %}

    {% if page.venue %}
      <p class="nerfies-venue">{{ page.venue }}</p>
    {% endif %}

    {% if page.project_links %}
      <div class="nerfies-links">
        {% for link in page.project_links %}
          {% if link.url %}
            {% assign link_url = link.url %}
            {% unless link_url contains '://' %}
              {% assign link_url = link_url | relative_url %}
            {% endunless %}
            <a
              class="nerfies-link"
              href="{{ link_url }}"
              target="_blank"
              rel="noopener noreferrer"
            >
              {% if link.icon %}
                <i class="{{ link.icon }}"></i>
              {% endif %}
              <span>{{ link.label | default: 'Link' }}</span>
            </a>
          {% elsif link.label or link.icon %}
            <span class="nerfies-link nerfies-link-disabled" aria-disabled="true">
              {% if link.icon %}
                <i class="{{ link.icon }}"></i>
              {% endif %}
              <span>{{ link.label | default: 'Link' }}</span>
            </span>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </header>

  {% if page.teaser_video or page.teaser_pdf or page.teaser_image %}
    <section class="nerfies-section">
      <div class="nerfies-teaser-media">
        {% if page.teaser_pdf %}
          {% assign teaser_pdf_url = page.teaser_pdf %}
          {% unless teaser_pdf_url contains '://' %}
            {% assign teaser_pdf_url = teaser_pdf_url | relative_url %}
          {% endunless %}
        {% endif %}

        {% if page.teaser_video %}
          {% assign teaser_video_url = page.teaser_video %}
          {% unless teaser_video_url contains '://' %}
            {% assign teaser_video_url = teaser_video_url | relative_url %}
          {% endunless %}
          <video autoplay loop muted playsinline controls preload="metadata">
            <source src="{{ teaser_video_url }}" type="{{ page.teaser_video_type | default: 'video/mp4' }}">
          </video>
        {% elsif page.teaser_image %}
          {% assign teaser_image_url = page.teaser_image %}
          {% unless teaser_image_url contains '://' %}
            {% assign teaser_image_url = teaser_image_url | relative_url %}
          {% endunless %}
          {% assign teaser_image_mobile_url = page.teaser_image_mobile %}
          {% if teaser_image_mobile_url %}
            {% unless teaser_image_mobile_url contains '://' %}
              {% assign teaser_image_mobile_url = teaser_image_mobile_url | relative_url %}
            {% endunless %}
          {% endif %}
          {% assign teaser_image_dark_url = page.teaser_image_dark | default: page.teaser_dark_image %}
          {% if teaser_image_dark_url %}
            {% unless teaser_image_dark_url contains '://' %}
              {% assign teaser_image_dark_url = teaser_image_dark_url | relative_url %}
            {% endunless %}
          {% endif %}
          {% assign teaser_image_dark_mobile_url = page.teaser_image_dark_mobile | default: page.teaser_dark_image_mobile %}
          {% if teaser_image_dark_mobile_url %}
            {% unless teaser_image_dark_mobile_url contains '://' %}
              {% assign teaser_image_dark_mobile_url = teaser_image_dark_mobile_url | relative_url %}
            {% endunless %}
          {% endif %}
          {% capture teaser_image_markup %}
            {% if teaser_image_dark_url %}
              <picture>
                {% if teaser_image_mobile_url %}
                  <source media="(max-width: 576px)" srcset="{{ teaser_image_mobile_url }}" />
                {% endif %}
                <img class="nerfies-teaser-image nerfies-teaser-image--light" src="{{ teaser_image_url }}" alt="{{ page.title }} teaser image (light theme)">
              </picture>
              <picture>
                {% if teaser_image_dark_mobile_url %}
                  <source media="(max-width: 576px)" srcset="{{ teaser_image_dark_mobile_url }}" />
                {% endif %}
                <img
                  class="nerfies-teaser-image nerfies-teaser-image--dark"
                  src="{{ teaser_image_dark_url }}"
                  alt="{{ page.title }} teaser image (dark theme)"
                  onerror="this.style.display='none'; var prev = this.parentElement && this.parentElement.previousElementSibling; if (prev) { var prevImg = prev.querySelector('img'); if (prevImg) { prevImg.style.display='block'; } }"
                >
              </picture>
            {% else %}
              <picture>
                {% if teaser_image_mobile_url %}
                  <source media="(max-width: 576px)" srcset="{{ teaser_image_mobile_url }}" />
                {% endif %}
                <img class="nerfies-teaser-image" src="{{ teaser_image_url }}" alt="{{ page.title }} teaser image">
              </picture>
            {% endif %}
          {% endcapture %}
          {% if teaser_pdf_url %}
            <a
              class="nerfies-teaser-pdf-preview"
              href="{{ teaser_pdf_url }}"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Open teaser PDF in a new tab"
            >
              {{ teaser_image_markup }}
            </a>
          {% else %}
            {{ teaser_image_markup }}
          {% endif %}
        {% elsif page.teaser_pdf %}
          {% assign teaser_pdf_rendered = true %}
          {% if page.teaser_pdf_preview %}
            {% assign teaser_pdf_preview_url = page.teaser_pdf_preview %}
            {% unless teaser_pdf_preview_url contains '://' %}
              {% assign teaser_pdf_preview_url = teaser_pdf_preview_url | relative_url %}
            {% endunless %}
            <a
              class="nerfies-teaser-pdf-preview"
              href="{{ teaser_pdf_url }}"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Open teaser PDF in a new tab"
            >
              <img src="{{ teaser_pdf_preview_url }}" alt="{{ page.title }} teaser preview">
            </a>
          {% else %}
            <object
              data="{{ teaser_pdf_url }}"
              type="application/pdf"
              aria-label="{{ page.title }} teaser PDF"
              style="height: {{ page.teaser_pdf_height | default: 560 }}px;"
            >
              <p>
                PDF preview is unavailable.
                <a href="{{ teaser_pdf_url }}" target="_blank" rel="noopener noreferrer">Open the PDF teaser</a>.
              </p>
            </object>
          {% endif %}
        {% endif %}
      </div>
      {% if teaser_pdf_rendered or (teaser_pdf_url and page.teaser_image == blank) %}
        <p class="nerfies-teaser-pdf-link">
          <a href="{{ teaser_pdf_url }}" target="_blank" rel="noopener noreferrer">Open teaser PDF in a new tab</a>
        </p>
      {% endif %}
      {% if page.teaser_caption %}
        <p class="nerfies-caption">{{ page.teaser_caption }}</p>
      {% endif %}
    </section>
  {% endif %}

  {% if page.abstract %}
    <section class="nerfies-section">
      <h2>Abstract</h2>
      <div class="nerfies-prose">{{ page.abstract | markdownify }}</div>
    </section>
  {% endif %}

  {% if page.highlights %}
    <section class="nerfies-section">
      <h2>Highlights</h2>
      <ul class="nerfies-highlights">
        {% for item in page.highlights %}
          <li>{{ item | markdownify }}</li>
        {% endfor %}
      </ul>
    </section>
  {% endif %}

  {% if page.feature_section %}
    {% include project_feature_section.liquid section=page.feature_section %}
  {% endif %}

  {% unless content == blank %}
    <section class="nerfies-section nerfies-prose">
      {{ content }}
    </section>
  {% endunless %}

  {% if page.citation %}
    <section class="nerfies-section">
      <h2>BibTeX</h2>
      <pre class="nerfies-bibtex"><code>{{ page.citation }}</code></pre>
    </section>
  {% endif %}

  {% if page.related_publications %}
    <section class="nerfies-section">
      <h2>References</h2>
      <div class="publications">
        {% bibliography --cited_in_order %}
      </div>
    </section>
  {% endif %}

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}

  <p class="nerfies-credit">
    Project page template inspired by
    <a href="https://github.com/nerfies/nerfies.github.io" target="_blank" rel="noopener noreferrer">Nerfies</a>.
  </p>
</article>
