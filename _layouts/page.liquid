---
layout: default
---
{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<div class="post">
  <header class="post-header{% if page.bib_search_in_header %} post-header-with-actions{% endif %}">
    <div class="post-header-row">
      <h1 class="post-title">{{ page.title }}</h1>
      {% if page.bib_search_in_header and site.bib_search %}
        <div class="post-header-action">
          {% include bib_search.liquid %}
        </div>
      {% endif %}
    </div>
    <p class="post-description">{{ page.description }}</p>
  </header>

  <article>
    {{ content }}
  </article>

  {% if page.related_publications %}
    <h2>References</h2>
    <div class="publications">
      {% bibliography --cited_in_order %}
    </div>
  {% endif %}

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>
